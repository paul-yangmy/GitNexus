# GitNexus Platform — Environment Variables
# Copy to .env.platform and update values before deploying.

# PostgreSQL
POSTGRES_PASSWORD=gitnexus_dev_2026

# JWT (MUST change in production)
JWT_SECRET=change_this_to_a_random_string

# MinIO Object Storage
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin123

# Ports (optional — defaults shown)
API_PORT=4747
HTTP_PORT=80
HTTPS_PORT=443
PG_PORT=5432
REDIS_PORT=6379
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Workers
ANALYZE_WORKERS=1
